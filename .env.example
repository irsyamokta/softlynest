# Copy file ini ke .env di VPS lalu isi nilainya
# cp .env.example .env

# Database (Supabase / PostgreSQL)
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/postgres

# Cloudinary
CLOUDINARY_KEY=
CLOUDINARY_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_URL=cloudinary://key:secret@cloud_name

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=
# Non-VITE alias for server-side runtime use
SUPABASE_URL=https://your-project.supabase.co
# Service role key — NEVER expose this to the client, server-only
SUPABASE_SERVICE_ROLE_KEY=

# Docker image (isi sesuai GitHub username/repo kamu)
GITHUB_REPOSITORY=yourusername/softlynest
IMAGE_TAG=latest
